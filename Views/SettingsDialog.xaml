<Window x:Class="AutoSaver.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="设置" Height="480" Width="380"
        MinHeight="420" MinWidth="360"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        WindowStyle="None" ResizeMode="NoResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Height="58" Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="设置" Style="{StaticResource H1}"/>
                        <TextBlock Text="主题、间隔与行为选项分组展示，窗口过小时可滚动浏览。"
                                   Style="{StaticResource Caption}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="✕" Style="{StaticResource GhostButton}"
                                Height="34" Width="40" MinWidth="40" Padding="0"
                                Foreground="{DynamicResource DangerColor}"
                                Click="OnCloseClick" ToolTip="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,18,20,16">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="主题" Style="{StaticResource H2}"/>
                            <TextBlock Text="切换界面明暗主题，所有控件会同步更新。" Style="{StaticResource Caption}" Margin="0,6,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ThemeDarkBtn"  Grid.Column="0" Content="深色"   Height="36" Click="OnThemeDarkClick"/>
                                <Button x:Name="ThemeLightBtn" Grid.Column="2" Content="浅色"   Height="36" Click="OnThemeLightClick"/>
                                <Button x:Name="ThemeSystemBtn" Grid.Column="4" Content="跟随系统" Height="36" Click="OnThemeSystemClick"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="检查间隔" Style="{StaticResource H2}"/>
                            <TextBlock Text="保存监控会把这里换算为秒数，仍然使用统一的内部间隔。"
                                       Style="{StaticResource Caption}" Margin="0,6,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="128"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="IntervalValueBox" Grid.Column="0" Text="30" Height="38"/>
                                <ComboBox x:Name="IntervalUnitCombo" Grid.Column="2" SelectedIndex="0" Height="38">
                                    <ComboBoxItem Content="秒"/>
                                    <ComboBoxItem Content="分"/>
                                    <ComboBoxItem Content="时"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="启动与关闭" Style="{StaticResource H2}"/>
                            <TextBlock Text="这些行为会影响程序如何启动和关闭。" Style="{StaticResource Caption}" Margin="0,6,0,18"/>
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="开机自启" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                        <TextBlock Text="随 Windows 一起启动。" Style="{StaticResource Caption}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="StartupCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>

                                <Separator/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="关闭到托盘" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                        <TextBlock Text="点关闭按钮时仅隐藏到系统托盘。" Style="{StaticResource Caption}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="TrayCloseCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>

                                <Separator/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="保存通知" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                        <TextBlock Text="保存完成后显示通知提示。" Style="{StaticResource Caption}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="NotifyCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>

                                <Separator/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="启动时自动检查更新" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                        <TextBlock Text="启动时联网检查是否有新版本。" Style="{StaticResource Caption}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="CheckUpdatesCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,1,0,0"
                    Padding="20,16,20,18">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Style="{StaticResource SecondaryButton}"
                            Height="36" Width="88" IsCancel="True" Margin="0,0,10,0"/>
                    <Button Content="保存" Style="{StaticResource PrimaryButton}"
                            Height="36" Width="88" IsDefault="True" Click="OnSaveClick"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
