<Window x:Class="AutoSaver.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="AutoSaver" Height="560" Width="360"
        MinHeight="400" MinWidth="300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Height="46" Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="AutoSaver" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                        <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="999"
                                Background="{DynamicResource BgTertiary}" VerticalAlignment="Center">
                            <TextBlock x:Name="VersionLabel" Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,-4,0">
                        <!-- Add -->
                        <Button Style="{StaticResource GhostButton}" Height="32" Width="32" MinWidth="32" Padding="0"
                                Click="OnAddClick" ToolTip="添加程序">
                            <Path Data="M12 5v14M5 12h14" Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                        <!-- Settings -->
                        <Button Style="{StaticResource GhostButton}" Height="32" Width="32" MinWidth="32" Padding="0"
                                Click="OnSettingsClick" ToolTip="设置">
                            <Path Data="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm0 0v0M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                                  Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                        <!-- Minimize -->
                        <Button Style="{StaticResource GhostButton}" Height="32" Width="32" MinWidth="32" Padding="0"
                                Click="OnMinimizeClick" ToolTip="最小化">
                            <Path Data="M5 12h14" Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" Width="14" Height="14" Stretch="Uniform"/>
                        </Button>
                        <!-- Close -->
                        <Button Style="{StaticResource GhostButton}" Height="32" Width="32" MinWidth="32" Padding="0"
                                Click="OnCloseClick" ToolTip="关闭">
                            <Path Data="M18 6L6 18M6 6l12 12" Stroke="{DynamicResource DangerColor}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Program list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,10,12,4"
                          CanContentScroll="False">
                <ListBox x:Name="ProgramListView" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackground}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1" CornerRadius="10"
                                    Padding="12,10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: name + status -->
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Status dot -->
                                            <Ellipse Width="7" Height="7" Fill="{Binding StatusColor}"
                                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding ExeSummary}" Style="{StaticResource Caption}"
                                                   Margin="14,3,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Exe}"/>
                                    </StackPanel>

                                    <!-- Right: icon buttons -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Edit -->
                                        <Button Style="{StaticResource GhostButton}" Height="28" Width="28" MinWidth="28"
                                                Padding="0" Click="OnEditClick" Tag="{Binding}" ToolTip="编辑">
                                            <Path Data="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
                                                  Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.6"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Width="13" Height="13" Stretch="Uniform"/>
                                        </Button>
                                        <!-- Delete -->
                                        <Button Style="{StaticResource GhostButton}" Height="28" Width="28" MinWidth="28"
                                                Padding="0" Click="OnDeleteClick" Tag="{Binding}" ToolTip="删除">
                                            <Path Data="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"
                                                  Stroke="{DynamicResource DangerColor}" StrokeThickness="1.6"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Width="13" Height="13" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,1,0,0"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusLabel" Text=""
                               Foreground="{DynamicResource TextMuted}" FontSize="11"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ProgramCountLabel" Text="0"
                                   Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                        <TextBlock Text=" 个程序 · "
                                   Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                        <TextBlock x:Name="RunningCountLabel" Text="0"
                                   Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                        <TextBlock Text=" 运行中"
                                   Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
