<Window x:Class="AutoSaver.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="AutoSaver" Height="520" Width="780"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Height="54" Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="AutoSaver" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                            <Border Margin="10,2,0,0" Padding="8,3" CornerRadius="999"
                                    Background="{DynamicResource BgTertiary}">
                                <TextBlock x:Name="VersionLabel" Style="{StaticResource Caption}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="自动保存程序管理器" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="+ 添加" Style="{StaticResource PrimaryButton}"
                                Height="34" MinWidth="92" Click="OnAddClick" Margin="0,0,10,0"/>
                        <Button Content="⚙" Style="{StaticResource SecondaryButton}"
                                Height="34" Width="40" MinWidth="40" Padding="0"
                                Click="OnSettingsClick" ToolTip="设置" Margin="0,0,10,0"/>
                        <Button Content="–" Style="{StaticResource GhostButton}"
                                Height="34" Width="40" MinWidth="40" Padding="0"
                                Click="OnMinimizeClick" ToolTip="最小化"/>
                        <Button Content="▢" Style="{StaticResource GhostButton}"
                                Height="34" Width="40" MinWidth="40" Padding="0"
                                Click="OnMaximizeRestoreClick" ToolTip="最大化/还原"/>
                        <Button Content="✕" Style="{StaticResource GhostButton}"
                                Height="34" Width="40" MinWidth="40" Padding="0"
                                Foreground="{DynamicResource DangerColor}"
                                Click="OnCloseClick" ToolTip="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Quick stats -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="18,16,18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="程序列表" Style="{StaticResource H2}"/>
                        <TextBlock Text="每个程序以独立卡片显示，状态和最近保存一目了然。" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="已配置" Style="{StaticResource Caption}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ProgramCountLabel" Text="0" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="运行中" Style="{StaticResource Caption}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="RunningCountLabel" Text="0" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Program list -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="18,16,18,16" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="18"
                              CanContentScroll="False">
                    <ListBox x:Name="ProgramListView" BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProgramCardBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*"/>
                                            <ColumnDefinition Width="1.4*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding ExeSummary}" Style="{StaticResource Caption}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Exe}"/>
                                            <TextBlock Text="{Binding LastSaveText}" Style="{StaticResource Caption}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                            <Border HorizontalAlignment="Left" Padding="10,4" CornerRadius="999"
                                                    Background="{DynamicResource BgTertiary}" Margin="0,0,0,10">
                                                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"
                                                           Foreground="{Binding StatusColor}"/>
                                            </Border>
                                            <TextBlock Text="{Binding IntervalText}" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding StatusBadgeText}" Style="{StaticResource Caption}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="编辑" Style="{StaticResource SecondaryButton}"
                                                    Click="OnEditClick" Tag="{Binding}" Margin="0,0,8,0"/>
                                            <Button Content="删除" Style="{StaticResource DangerButton}"
                                                    Click="OnDeleteClick" Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="3" Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,1,0,0"
                    Padding="18,10">
                <TextBlock x:Name="StatusLabel" Text=""
                           Foreground="{DynamicResource TextSecondary}" FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>
    </Border>
</Window>
