<Window x:Class="AutoSaver.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:conv="clr-namespace:AutoSaver.Converters"
        Title="AutoSaver" Height="480" Width="300"
        MinHeight="360" MinWidth="260"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="True">

    <Window.Resources>
        <conv:BoolToPausePlayPathConverter x:Key="BoolToPausePlayPath"/>
        <conv:BoolToToggleColorConverter x:Key="BoolToToggleColor"/>
        <conv:BoolToToggleFillConverter x:Key="BoolToToggleFill"/>
        <conv:BoolToToggleTipConverter x:Key="BoolToToggleTip"/>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="12" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Height="44" Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="AutoSaver" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                        <Border Margin="7,0,0,0" Padding="5,2" CornerRadius="999"
                                Background="{DynamicResource BgTertiary}" VerticalAlignment="Center">
                            <TextBlock x:Name="VersionLabel" Style="{StaticResource Caption}" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Countdown capsule -->
                        <Border x:Name="CountdownCapsule" Style="{StaticResource CountdownCapsule}"
                                Margin="0,0,6,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm0 5v5l3 3"
                                      Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"
                                      Margin="0,0,4,0"/>
                                <TextBlock x:Name="CountdownLabel" Style="{StaticResource Caption}"
                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Minimize -->
                        <Button Style="{StaticResource GhostButton}" Height="30" Width="30" MinWidth="30" Padding="0"
                                Click="OnMinimizeClick" ToolTip="最小化">
                            <Path Data="M5 12h14" Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" Width="12" Height="12" Stretch="Uniform"/>
                        </Button>
                        <!-- Close -->
                        <Button Style="{StaticResource GhostButton}" Height="30" Width="30" MinWidth="30" Padding="0"
                                Click="OnCloseClick" ToolTip="关闭">
                            <Path Data="M18 6L6 18M6 6l12 12" Stroke="{DynamicResource DangerColor}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="11" Height="11" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Program list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="10,8,10,4"
                          CanContentScroll="False">
                    <ListBox x:Name="ProgramListView" BorderThickness="0" Background="Transparent"
                         SelectionChanged="OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource ProgramCardBorder}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                    <Setter Property="Background" Value="{DynamicResource BgTertiary}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Source="{Binding Icon}" Width="20" Height="20"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Row="0" Grid.Column="0" Width="6" Height="6" Fill="{Binding StatusColor}"
                                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1"
                                                           Text="{Binding ExeSummary}" Style="{StaticResource Caption}"
                                                           Margin="0,3,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Exe}"/>
                                            </Grid>
                                        </Grid>
                                        <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                                Height="28" Width="28" MinWidth="28" Padding="0"
                                                Click="OnToggleEnabledClick" Tag="{Binding}"
                                                ToolTip="{Binding Enabled, Converter={StaticResource BoolToToggleTip}}">
                                            <Path Data="{Binding Enabled, Converter={StaticResource BoolToPausePlayPath}}"
                                                  Stroke="{Binding Enabled, Converter={StaticResource BoolToToggleColor}}"
                                                  StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Fill="{Binding Enabled, Converter={StaticResource BoolToToggleFill}}"
                                                  Width="13" Height="13" Stretch="Uniform"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
            </ScrollViewer>

            <!-- Bottom toolbar -->
            <Border Grid.Row="2" Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,1,0,0"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Add -->
                    <Button Grid.Column="0" Style="{StaticResource PrimaryButton}"
                            Height="30" MinWidth="64" Padding="10,0"
                            Click="OnAddClick" ToolTip="添加程序">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 5v14M5 12h14" Stroke="{DynamicResource OnPrimaryForeground}" StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="添加" Foreground="{DynamicResource OnPrimaryForeground}" FontSize="12"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Delete -->
                    <Button x:Name="DeleteButton" Grid.Column="1" Style="{StaticResource DangerButton}"
                            Height="30" MinWidth="64" Padding="10,0" Margin="8,0,0,0"
                            IsEnabled="False" Click="OnDeleteClick" ToolTip="删除选中程序">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"
                                  Stroke="{DynamicResource DangerColor}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="删除" Foreground="{DynamicResource DangerColor}" FontSize="12"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- About -->
                    <Button Grid.Column="3" Style="{StaticResource GhostButton}"
                            Height="30" Width="30" MinWidth="30" Padding="0"
                            Click="OnAboutClick" ToolTip="关于 AutoSaver">
                        <Border Width="16" Height="16" CornerRadius="8"
                                BorderBrush="{DynamicResource TextSecondary}" BorderThickness="1.4">
                            <TextBlock Text="?" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="11" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Button>

                    <!-- Settings -->
                    <Button Grid.Column="4" Style="{StaticResource GhostButton}"
                            Height="30" Width="30" MinWidth="30" Padding="0"
                            Click="OnSettingsClick" ToolTip="设置">
                        <Path Data="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                              Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.4"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
