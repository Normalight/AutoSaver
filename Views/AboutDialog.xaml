<Window x:Class="AutoSaver.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="关于 AutoSaver" Height="620" Width="520"
        MinHeight="560" MinWidth="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        WindowStyle="None" ResizeMode="NoResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Height="58" Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="关于 AutoSaver" Style="{StaticResource H1}"/>
                        <TextBlock Text="版本信息、仓库链接与更新操作。" Style="{StaticResource Caption}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="✕" Style="{StaticResource GhostButton}"
                            Height="34" Width="40" MinWidth="40" Padding="0"
                            Foreground="{DynamicResource DangerColor}"
                            Click="OnCloseClick" ToolTip="关闭"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="20,18,20,16">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="AutoSaver" Style="{StaticResource H2}"/>
                            <TextBlock x:Name="CurrentVersionText" Text="当前版本：-" Margin="0,8,0,0"
                                       Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                            <TextBlock Text="自动向目标程序发送 Ctrl+S，帮助你在绘图和创作时减少忘记保存的风险。"
                                       Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                            <TextBlock Text="作者：Normalight" Style="{StaticResource Caption}" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="仓库" Style="{StaticResource H2}"/>
                            <TextBlock Text="GitHub Releases 是唯一发布源。" Style="{StaticResource Caption}" Margin="0,6,0,14"/>
                            <Button x:Name="RepositoryButton" Content="打开 GitHub 仓库"
                                    Style="{StaticResource SecondaryButton}" Height="36"
                                    HorizontalAlignment="Left" Click="OnOpenRepositoryClick"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="更新" Style="{StaticResource H2}"/>
                            <TextBlock x:Name="UpdateStatusText" Text="尚未检查更新" Style="{StaticResource Caption}" Margin="0,6,0,0"/>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="当前版本" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock x:Name="UpdateCurrentVersionText" Grid.Column="1" Margin="16,0,0,0"
                                           Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="最新版本" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock x:Name="UpdateLatestVersionText" Grid.Column="1" Margin="16,0,0,0"
                                           Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                            </Grid>

                            <ProgressBar x:Name="DownloadProgressBar" Height="8" Margin="0,16,0,0"
                                         Minimum="0" Maximum="100" Visibility="Collapsed"/>
                            <TextBlock x:Name="DownloadProgressText" Style="{StaticResource Caption}"
                                       Margin="0,8,0,0" Visibility="Collapsed"/>

                            <TextBlock Text="更新说明" Style="{StaticResource H2}" Margin="0,18,0,0"/>
                            <Border Background="{DynamicResource BgTertiary}" CornerRadius="10" Padding="12" Margin="0,10,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="180">
                                    <TextBlock x:Name="ReleaseNotesText" Style="{StaticResource Body}" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,1,0,0"
                    Padding="20,16,20,18">
                <WrapPanel HorizontalAlignment="Right" ItemHeight="36" ItemWidth="Auto">
                    <Button x:Name="OpenReleaseButton" Content="打开发布页" Style="{StaticResource SecondaryButton}"
                            Height="36" Margin="0,0,10,0" Click="OnOpenReleaseClick" Visibility="Collapsed"/>
                    <Button x:Name="CheckUpdateButton" Content="检查更新" Style="{StaticResource SecondaryButton}"
                            Height="36" Margin="0,0,10,0" Click="OnCheckUpdateClick"/>
                    <Button x:Name="InstallUpdateButton" Content="下载并安装更新" Style="{StaticResource PrimaryButton}"
                            Height="36" Click="OnInstallUpdateClick" IsEnabled="False"/>
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</Window>
