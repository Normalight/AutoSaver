<Window x:Class="AutoSaver.Views.NotificationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        ShowInTaskbar="False" Height="56" Width="420"
        WindowStartupLocation="Manual"
        Background="Transparent">

    <Border x:Name="RootBorder" CornerRadius="8" Padding="14,0"
            Background="{DynamicResource BgSecondary}"
            BorderThickness="1" BorderBrush="{DynamicResource BorderColor}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Status bar (colored) -->
            <Border x:Name="StatusBar" Grid.Column="0" CornerRadius="2"
                    Margin="-14,8,10,8" Width="4"/>

            <!-- Message -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="13" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="DetailText" FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           TextTrimming="CharacterEllipsis" MaxWidth="280"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                <Button x:Name="JumpButton" Content="跳转 →" Style="{StaticResource PrimaryButton}"
                        Height="28" FontSize="12" Padding="10,0" MinWidth="60"
                        Click="OnJumpClick" Visibility="Collapsed"/>
                <Button x:Name="CloseButton" Content="✕"
                        Style="{StaticResource GhostButton}"
                        Height="28" Width="28" FontSize="14" Padding="0"
                        Click="OnCloseClick" Margin="6,0,0,0"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
