<Window x:Class="AutoSaver.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="620" Width="520"
        MinHeight="520" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResize">

    <Border Background="{DynamicResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource WindowChromeBackground}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid Height="54" Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="设置" Style="{StaticResource H1}"/>
                        <TextBlock Text="主题、间隔与行为选项分组展示，窗口过小时可滚动浏览。"
                                   Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="–" Style="{StaticResource GhostButton}"
                                Height="34" Width="40" MinWidth="40" Padding="0"
                                Click="OnMinimizeClick" ToolTip="最小化" Margin="0,0,10,0"/>
                        <Button Content="✕" Style="{StaticResource GhostButton}"
                                Height="34" Width="40" MinWidth="40" Padding="0"
                                Foreground="{DynamicResource DangerColor}"
                                Click="OnCloseClick" ToolTip="关闭"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="18,16">
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="主题" Style="{StaticResource H2}"/>
                            <TextBlock Text="切换界面明暗主题，所有控件会同步更新。" Style="{StaticResource Caption}" Margin="0,6,0,14"/>
                            <ComboBox x:Name="ThemeCombo" Height="36">
                                <ComboBoxItem Content="深色"/>
                                <ComboBoxItem Content="浅色"/>
                                <ComboBoxItem Content="跟随系统"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="检查间隔" Style="{StaticResource H2}"/>
                            <TextBlock Text="保存监控会把这里换算为秒数，仍然使用统一的内部间隔。"
                                       Style="{StaticResource Caption}" Margin="0,6,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="IntervalValueBox" Grid.Column="0" Text="30"/>
                                <ComboBox x:Name="IntervalUnitCombo" Grid.Column="2" SelectedIndex="0">
                                    <ComboBoxItem Content="秒"/>
                                    <ComboBoxItem Content="分"/>
                                    <ComboBoxItem Content="时"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="启动与关闭" Style="{StaticResource H2}"/>
                            <TextBlock Text="这些行为会影响程序如何启动和关闭。" Style="{StaticResource Caption}" Margin="0,6,0,14"/>
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="开机自启" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                        <TextBlock Text="随 Windows 一起启动。" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="StartupCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>

                                <Separator/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="关闭到托盘" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                        <TextBlock Text="点关闭按钮时仅隐藏到系统托盘。" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="TrayCloseCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>

                                <Separator/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="保存通知" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                        <TextBlock Text="保存完成后显示通知提示。" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="NotifyCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,16,18,18">
                <Button Content="取消" Style="{StaticResource SecondaryButton}"
                        Height="36" Width="88" IsCancel="True" Margin="0,0,10,0"/>
                <Button Content="保存" Style="{StaticResource PrimaryButton}"
                        Height="36" Width="88" IsDefault="True" Click="OnSaveClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
