<Window x:Class="AutoSaver.Views.CountdownOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        ShowActivated="False" ShowInTaskbar="False"
        Height="44" Width="132"
        WindowStartupLocation="Manual"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Grayscale"
        MouseLeftButtonDown="OnDragStart">

    <Grid Margin="4" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Border CornerRadius="18"
                Background="Transparent"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4"
                                  ShadowDepth="0"
                                  Direction="270"
                                  Opacity="0.18"
                                  Color="#000000"/>
            </Border.Effect>
        </Border>

        <Border x:Name="GlassBorder"
                CornerRadius="18"
                Background="{DynamicResource CountdownOverlayBg}"
                BorderBrush="{DynamicResource CountdownOverlayBorder}"
                BorderThickness="1"
                Padding="15,0"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <Border.CacheMode>
                <BitmapCache RenderAtScale="1"/>
            </Border.CacheMode>

            <Grid ClipToBounds="True">
                <Border CornerRadius="17"
                        Height="15"
                        VerticalAlignment="Top"
                        Margin="1"
                        Background="{DynamicResource CountdownOverlayHighlight}"
                        Opacity="0.32"
                        IsHitTestVisible="False"/>

                <Border x:Name="FlashLayer"
                        CornerRadius="16"
                        Background="Transparent"
                        Opacity="0"
                        Margin="1"
                        IsHitTestVisible="False"/>

                <StackPanel x:Name="ContentPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                    <Path Data="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm0 5v5l3 3"
                          Stroke="{DynamicResource CountdownOverlayIcon}"
                          StrokeThickness="1.45"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Width="12"
                          Height="12"
                          Stretch="Uniform"
                          VerticalAlignment="Center"
                          Margin="0,0,7,0"
                          Opacity="0.82"
                          SnapsToDevicePixels="True"/>
                    <TextBlock x:Name="CountdownText"
                               Text="30s"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource CountdownOverlayText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
