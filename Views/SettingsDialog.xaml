<Window x:Class="AutoSaver.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="400" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="设置" Style="{StaticResource H1}" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <!-- Theme -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="主题" VerticalAlignment="Center" Style="{StaticResource Body}"/>
                <ComboBox x:Name="ThemeCombo" Grid.Column="1" Height="34">
                    <ComboBoxItem Content="深色"/>
                    <ComboBoxItem Content="浅色"/>
                    <ComboBoxItem Content="跟随系统"/>
                </ComboBox>
            </Grid>

            <Separator/>

            <!-- Check interval -->
            <Grid Margin="0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="检查间隔" VerticalAlignment="Center" Style="{StaticResource Body}"/>
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <TextBox x:Name="IntervalBox" Width="64" Height="34" Text="3"/>
                    <TextBlock Text=" 秒" VerticalAlignment="Center" Style="{StaticResource Body}"/>
                </StackPanel>
            </Grid>

            <Separator/>

            <!-- Startup -->
            <Grid Margin="0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="开机自启" VerticalAlignment="Center" Style="{StaticResource Body}"/>
                <CheckBox x:Name="StartupCheck" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>

            <Separator/>

            <!-- Tray close -->
            <Grid Margin="0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="关闭到托盘" VerticalAlignment="Center" Style="{StaticResource Body}"/>
                <CheckBox x:Name="TrayCloseCheck" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>

            <Separator/>

            <!-- Notifications -->
            <Grid Margin="0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="保存通知" VerticalAlignment="Center" Style="{StaticResource Body}"/>
                <CheckBox x:Name="NotifyCheck" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Style="{StaticResource GhostButton}"
                    Height="36" Width="80" IsCancel="True" Margin="0,0,10,0"/>
            <Button Content="保存" Style="{StaticResource PrimaryButton}"
                    Height="36" Width="80" IsDefault="True" Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
